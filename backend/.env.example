# Copy this file to ".env" and fill in real values.
# The .env file is gitignored — never commit it.

# Your private owner password (full access incl. portfolio).
OWNER_PASSWORD=choose-a-strong-password

# The join code you give to guests (market tools only).
ACCESS_CODE=TSLA5574

# Secret used to sign login tokens. Make it long and random.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=paste-a-long-random-string-here

# Which sites may call this API (comma-separated, no trailing slash).
# Add your real domain + the Netlify preview URL once you deploy.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://williamgrip.se,https://www.williamgrip.se

# Your Anthropic API key — powers the Claude assistant + Deep Research engine.
# Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Financial Modeling Prep — screener + congressional trades (financialmodelingprep.com)
FMP_API_KEY=

# SEC EDGAR requires a contact in the User-Agent or it returns 403.
SEC_USER_AGENT=Meridian/1.0 your-email@example.com

# Which Claude model the Deep Research engine uses.
RESEARCH_MODEL=claude-sonnet-4-6

# ── Signal engine (all OPTIONAL — engine runs without them) ──
NEWS_API_KEY=          # newsapi.org → free API key
FINNHUB_KEY=           # finnhub.io → free API key
TWITTER_BEARER_TOKEN=  # developer.twitter.com → Bearer Token (social signal)

# ── The Eye: space, satellite & patent intelligence (all OPTIONAL) ──
COPERNICUS_USER=       # dataspace.copernicus.eu → free account (Sentinel-2 imagery)
COPERNICUS_PASS=
ACLED_USERNAME=        # acleddata.com → myACLED login email (OAuth, conflict data)
ACLED_PASSWORD=        # your myACLED account password
EPO_OPS_KEY=           # developers.epo.org → My Apps → Consumer Key (patent search, free, no ID)
EPO_OPS_SECRET=        # the matching Consumer Secret
SATELLITE_DATA_DIR=./satellite-cache
# Sentinel Hub OAuth client (OPTIONAL) — upgrades Operations to true-color VISION
# analysis. Create at dataspace.copernicus.eu → User Settings → OAuth clients.
SH_CLIENT_ID=
SH_CLIENT_SECRET=
