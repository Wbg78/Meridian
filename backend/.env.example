# Copy this file to ".env" and fill in real values.
# The .env file is gitignored — never commit it.

# Your private owner password (full access incl. portfolio).
OWNER_PASSWORD=choose-a-strong-password

# The join code you give to guests (market tools only).
ACCESS_CODE=TSLA5574

# Secret used to sign login tokens. Make it long and random.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=paste-a-long-random-string-here

# Which sites may call this API (comma-separated, no trailing slash).
# Add your real domain + the Netlify preview URL once you deploy.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://williamgrip.se,https://www.williamgrip.se

# Your Anthropic API key — powers the Claude assistant in the app.
# Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
